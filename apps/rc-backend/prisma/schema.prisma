generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model CatalogCategory {
  id        String        @id
  slug      String        @unique
  title     String
  subtitle  String
  icon      String
  status    String        @default("active")
  sortOrder Int           @map("sort_order")
  items     CatalogItem[]

  @@map("catalog_categories")
}

model CateringPackage {
  id          String  @id
  slug        String  @unique
  name        String
  tagline     String
  description String  @db.Text
  accent      String  @default("dark")
  priceCents  Int     @map("price_cents")
  currency    String  @default("SGD")
  minGuests   Int     @map("min_guests")
  badge       String?
  features    Json    @default("[]")
  status      String  @default("active")
  sortOrder   Int     @map("sort_order")

  @@index([status])
  @@map("catering_packages")
}

enum DietarySpiceLevel {
  MILD
  MEDIUM
  HOT
  EXTRA

  @@map("dietary_spice_level")
}

model MenuCategory {
  id        String     @id
  slug      String     @unique
  name      String
  sortOrder Int        @map("sort_order")
  status    String     @default("active")
  items     MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id          String             @id
  slug        String             @unique
  categoryId  String             @map("category_id")
  category    MenuCategory       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name        String
  description String             @db.Text
  priceCents  Int?               @map("price_cents")
  currency    String             @default("SGD")
  variants    Json               @default("[]")
  imageSlug   String             @map("image_slug")
  veg         Boolean            @default(false)
  vegan       Boolean?
  glutenFree  Boolean?           @map("gluten_free")
  spiceLevel  DietarySpiceLevel? @map("spice_level")
  allergens   String[]           @default([])
  status      String             @default("active")
  sortOrder   Int                @map("sort_order")

  @@index([categoryId, sortOrder])
  @@index([status])
  @@map("menu_items")
}

model CatalogItem {
  id          String          @id
  slug        String          @unique
  categoryId  String          @map("category_id")
  category    CatalogCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name        String
  description String          @db.Text
  story       String?         @db.Text
  imageUrl    String?         @map("image_url")
  priceCents  Int             @map("price_cents")
  currency    String          @default("SGD")
  tags        String[]        @default([])
  ingredients String[]        @default([])
  status      String          @default("active")
  sortOrder   Int             @map("sort_order")

  @@index([categoryId, sortOrder])
  @@index([status])
  @@map("catalog_items")
}

model AuditLog {
  id         String   @id @default(cuid())
  actor      String
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  before     Json?
  after      Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Promotion {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  ctaLabel    String?  @map("cta_label")
  ctaHref     String?  @map("cta_href")
  placement   String   @default("home")
  status      String   @default("active")
  startsAt    DateTime? @map("starts_at")
  endsAt      DateTime? @map("ends_at")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([placement, status])
  @@index([sortOrder])
  @@map("promotions")
}

model GalleryImage {
  id        String   @id @default(cuid())
  title     String
  alt       String
  imageUrl  String   @map("image_url")
  category  String   @default("food")
  status    String   @default("active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category, status])
  @@index([sortOrder])
  @@map("gallery_images")
}

model Testimonial {
  id        String   @id @default(cuid())
  author    String
  quote     String   @db.Text
  source    String?
  rating    Int?
  status    String   @default("active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([sortOrder])
  @@map("testimonials")
}

model SiteSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model Customer {
  id             String         @id @default(cuid())
  googleSub      String?        @unique @map("google_sub")
  name           String?
  email          String?        @unique
  phone          String?        @unique
  marketingOptIn Boolean        @default(false) @map("marketing_opt_in")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  bookings       Booking[]
  eventEnquiries EventEnquiry[]
  orders         Order[]
  otps           CustomerOtp[]
  sessions       CustomerSession[]

  @@index([createdAt])
  @@map("customers")
}

model CustomerOtp {
  id             String    @id @default(cuid())
  customerId     String    @map("customer_id")
  customer       Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  channel        String
  destination    String
  codeHash       String    @map("code_hash")
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedAt       DateTime? @map("locked_at")
  expiresAt      DateTime  @map("expires_at")
  consumedAt     DateTime? @map("consumed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([customerId])
  @@index([destination, createdAt])
  @@map("customer_otps")
}

model CustomerSession {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique @map("token_hash")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([customerId])
  @@index([expiresAt])
  @@map("customer_sessions")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED

  @@map("booking_status")
}

model Booking {
  id           String        @id @default(cuid())
  customerId   String?       @map("customer_id")
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName String        @map("customer_name")
  email        String
  phone        String
  partySize    Int           @map("party_size")
  bookedFor    DateTime      @map("booked_for")
  notes        String?       @db.Text
  status       BookingStatus @default(PENDING)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@index([bookedFor])
  @@index([status])
  @@index([customerId])
  @@map("bookings")
}

enum EventEnquiryStatus {
  NEW
  CONTACTED
  CONFIRMED
  CANCELLED
  CLOSED

  @@map("event_enquiry_status")
}

model EventEnquiry {
  id            String             @id @default(cuid())
  customerId    String?            @map("customer_id")
  customer      Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName  String             @map("customer_name")
  email         String
  phone         String
  eventType     String             @map("event_type")
  guestCount    Int                @map("guest_count")
  preferredDate DateTime?          @map("preferred_date")
  notes         String?            @db.Text
  source        String             @default("form")
  externalId    String?            @map("external_id")
  status        EventEnquiryStatus @default(NEW)
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  @@index([status])
  @@index([preferredDate])
  @@index([customerId])
  @@map("event_enquiries")
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED

  @@map("order_status")
}

enum PaymentStatus {
  REQUIRES_PAYMENT
  PAID
  FAILED
  REFUNDED

  @@map("payment_status")
}

model Order {
  id                    String        @id @default(cuid())
  customerId            String?       @map("customer_id")
  customer              Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName          String        @map("customer_name")
  email                 String?
  phone                 String
  fulfillmentType       String        @map("fulfillment_type")
  requestedAt           DateTime?     @map("requested_at")
  address               String?       @db.Text
  notes                 String?       @db.Text
  subtotalCents         Int           @map("subtotal_cents")
  taxCents              Int           @map("tax_cents")
  deliveryFeeCents      Int           @map("delivery_fee_cents")
  totalCents            Int           @map("total_cents")
  currency              String        @default("SGD")
  status                OrderStatus   @default(PENDING_PAYMENT)
  paymentStatus         PaymentStatus @default(REQUIRES_PAYMENT) @map("payment_status")
  stripePaymentIntentId String?       @unique @map("stripe_payment_intent_id")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  items                 OrderItem[]

  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([customerId])
  @@map("orders")
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String  @map("order_id")
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId     String  @map("menu_item_id")
  name           String
  unitPriceCents Int     @map("unit_price_cents")
  quantity       Int
  notes          String? @db.Text
  totalCents     Int     @map("total_cents")

  @@index([orderId])
  @@index([menuItemId])
  @@map("order_items")
}
