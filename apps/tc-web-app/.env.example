# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# Top strip contact details (AppHeader)
NEXT_PUBLIC_CONTACT_PHONE_DISPLAY="+65 9000 1111"
NEXT_PUBLIC_CONTACT_PHONE_HREF="tel:+6590001111"
NEXT_PUBLIC_CONTACT_ADDRESS="123 Demo Street #02-08 Sample Plaza, Singapore 123456"
NEXT_PUBLIC_CONTACT_MAP_URL="https://maps.example.com/demo-location"
NEXT_PUBLIC_CONTACT_MAP_EMBED_URL="https://www.google.com/maps/embed?pb=demo"

# Top strip social links (AppHeader)
NEXT_PUBLIC_SOCIAL_FACEBOOK_URL="https://facebook.com/demo-tandoori-page"
NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL="https://instagram.com/demo.tandoori.page"
NEXT_PUBLIC_SOCIAL_TRIPADVISOR_URL="https://tripadvisor.com/Restaurant_Review-demo"

# Footer links
NEXT_PUBLIC_SOCIAL_X_URL="https://x.com/demo_tandoori"
NEXT_PUBLIC_CONTACT_EMAIL="mailto:hello@demo-tandoori.test"

# Backend catalog API (rc-backend). Used server-side to render the menu page.
RC_BACKEND_URL="http://localhost:4000"
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"

# Optional checkout account sign-in.
NEXT_PUBLIC_GOOGLE_CLIENT_ID="google-web-client-id.apps.googleusercontent.com"

# Optional third-party/client widgets. Keep disabled for the fastest public pages.
NEXT_PUBLIC_ENABLE_CHATBOT="false"
NEXT_PUBLIC_ENABLE_VERCEL_ANALYTICS="false"
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_FB_PIXEL_ID=""
# Google Search Console HTML-tag verification token (the content="..." value)
NEXT_PUBLIC_GSC_VERIFICATION=""
