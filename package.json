{
  "name": "tandoori-corner-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter tc-web-app dev",
    "dev:backend": "pnpm --filter rc-backend dev",
    "dev:web": "pnpm --filter tc-web-app dev",
    "build": "pnpm -r build",
    "build:backend": "pnpm --filter rc-backend build",
    "build:web": "pnpm --filter tc-web-app build",
    "test:e2e": "playwright test",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@playwright/test": "^1.61.1"
  }
}
